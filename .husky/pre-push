#!/usr/bin/env sh
# Pre-push: full quality gate. Runs three checks in order. Any failure
# blocks the push. All checks live here (not split to pre-commit) so
# commits are fast and batch-friendly per user preference.

set -e

echo "[pre-push] 1/3 ESLint..."
npm run lint

echo "[pre-push] 2/3 TypeScript type check..."
npx tsc --noEmit

echo "[pre-push] 3/3 Next.js production build..."
npm run build

echo "[pre-push] All checks passed. Safe to push."
