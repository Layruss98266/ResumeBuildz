# ResumeBuildz Environment Variables
#
# Copy this file to .env.local and fill in the values.
# Without any vars set the app runs in guest-stub mode (localStorage only, no auth, no billing).
#
# Groq AI: No server-side key needed. Users supply their own key in the browser.
# Get a free Groq API key at: https://console.groq.com/keys

# ─── Supabase (Auth + Cloud Sync) ────────────────────────────────────────────
# Get these from supabase.com → Project Settings → API
# Omit both to run in guest-only mode (no sign-in, no cloud save).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Server-only — used exclusively in app/api/stripe/webhook after Stripe
# signature verification to update profiles.plan. Never exposed client-side.
# Get it from supabase.com → Project Settings → API → service_role key.
SUPABASE_SERVICE_ROLE_KEY=

# ─── Site URL ─────────────────────────────────────────────────────────────────
# Canonical origin for OAuth redirects and share-link generation.
# Change to your production URL before deploying.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Stripe (Billing) ─────────────────────────────────────────────────────────
# Omit all Stripe vars to disable paid plans entirely (free tier still works).
# Get keys from dashboard.stripe.com → Developers → API keys.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Price IDs for each plan — from Stripe dashboard → Products.
NEXT_PUBLIC_STRIPE_PRICE_STARTER=
NEXT_PUBLIC_STRIPE_PRICE_PRO=
NEXT_PUBLIC_STRIPE_PRICE_TEAM=
NEXT_PUBLIC_STRIPE_PRICE_LIFETIME=

# ─── Email (Share Invites) ────────────────────────────────────────────────────
# Resend is used to send share-invite emails. Omit to disable email; the UI
# falls back to "copy link" mode automatically.
# Get your API key from resend.com → API Keys.
RESEND_API_KEY=

# From address for share-invite emails.
# Must be a domain you've verified in Resend.
SHARE_INVITE_FROM=ResumeBuildz <noreply@yourdomain.com>

# ─── Analytics & Monitoring ───────────────────────────────────────────────────
# Vercel Web Analytics: enable in the Vercel dashboard under Analytics.
# No environment variable required.

# Sentry (optional). Leave blank to disable error monitoring.
# Sign up at sentry.io, create a Next.js project, copy the DSN here.
NEXT_PUBLIC_SENTRY_DSN=
