# ResumeForge Environment Variables
#
# Groq AI: No server-side key needed. Users enter their own key in the browser.
# Get a free Groq API key at: https://console.groq.com/keys
#
# Supabase Auth: Get these from supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Site URL — change to your production URL for deployment
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Plausible Analytics (optional, privacy-friendly, no cookies)
# Get a free account at https://plausible.io and add your domain
# Leave blank to disable analytics
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=resume-forge-orcin.vercel.app
