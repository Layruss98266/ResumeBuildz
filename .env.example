# ResumeBuildz Environment Variables
#
# Groq AI: No server-side key needed. Users enter their own key in the browser.
# Get a free Groq API key at: https://console.groq.com/keys
#
# Supabase Auth: Get these from supabase.com → Project Settings → API
# Only the public anon key is needed — the app does all DB work as the
# authenticated user, never with a service-role key.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Site URL — change to your production URL for deployment
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Analytics: ResumeBuildz uses Vercel Web Analytics (free on Hobby plan).
# Enable it in the Vercel dashboard under Project Settings → Analytics.
# No environment variable is required.

# Sentry (optional). Leave blank to disable error monitoring entirely.
# Sign up at sentry.io, create a Next.js project, copy the DSN here.
# App + Edge Functions auto-capture exceptions when this is set.
NEXT_PUBLIC_SENTRY_DSN=
